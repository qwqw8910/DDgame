# Supabase 設定（使用 service_role key，可繞過 RLS）
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 前端來源（GitHub Pages URL，避免 CORS 錯誤）
# 多個來源用逗號分隔，例如：https://yourname.github.io,http://localhost:3000
CORS_ORIGIN=https://yourname.github.io,http://localhost:5500,http://127.0.0.1:5500

# 伺服器 Port（Railway/Render 會自動注入 PORT 環境變數）
PORT=5500

# 默契傳聲筒題庫模式
# CS_WEEKDAY_MODE=fixed: 固定使用 CS_WEEKDAY_OVERRIDE
# CS_WEEKDAY_MODE=auto: 依照系統星期幾（0=日,1=一,...,6=六）
CS_WEEKDAY_MODE=fixed

# 目前先鎖定星期二題庫
CS_WEEKDAY_OVERRIDE=2
